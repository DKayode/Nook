# Shared by docker-compose
POSTGRES_USER=expense
POSTGRES_PASSWORD=changeme
POSTGRES_DB=expense
DATABASE_URL=postgresql://expense:changeme@db:5432/expense

# Web (Next.js / NextAuth)
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_TRUST_HOST=true

# Email (magic-link auth). Mailpit catches everything locally — UI at http://localhost:8025
EMAIL_SERVER=smtp://mail:1025
EMAIL_FROM="Expense Tracker <no-reply@expense.local>"

# Internal service-to-service
API_INTERNAL_URL=http://api:8000
API_INTERNAL_TOKEN=replace-with-shared-secret

# FastAPI (LLM for CSV column detection + transaction categorization)
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
