# Caddy auto-provisions Let's Encrypt certs. Replace the host with your real domain at deploy time
# (or set DOMAIN env var and use {$DOMAIN}). The web service listens on :3000 inside the docker network.

{$DOMAIN} {
	encode gzip zstd

	# Pass everything to the Next.js app
	reverse_proxy web:3000

	# assetlinks.json must be served as application/json with no auth interception
	handle /.well-known/assetlinks.json {
		header Content-Type application/json
		reverse_proxy web:3000
	}

	# Security headers
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), camera=(), microphone=()"
		-Server
	}
}
